# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/order_management_db?schema=public&connection_limit=20&pool_timeout=30"
DATABASE_POOL_SIZE=20
DATABASE_MAX_CONNECTIONS=100

# Connection Pool Settings
# Tăng pool size để xử lý nhiều request đồng thời
# Nếu vẫn gặp lỗi "max clients reached", giảm giá trị này xuống 10-15

# PostgreSQL Server Settings (cần cấu hình trong postgresql.conf)
# max_connections = 200
# shared_buffers = 128MB
# effective_cache_size = 512MB

# Application
NODE_ENV=development
PORT=3001

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=15m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Email - SMTP (Gửi email ra ngoài) ───────────────────────────────────────
# Gmail: Bật "Less secure app access" hoặc dùng App Password (16 ký tự)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-16-chars
EMAIL_FROM_EMAIL=your-email@gmail.com
EMAIL_FROM_NAME=OMS System

# ─── Email - IMAP (Đọc email đến, dùng cho RAG + auto-PR) ───────────────────
EMAIL_IMAP_HOST=imap.gmail.com

# ─── AI Services ─────────────────────────────────────────────────────────────
# Google Gemini (phân tích email, gợi ý sản phẩm, đánh giá NCC)
GEMINI_API_KEY=your-gemini-api-key-here

# FPT AI (Embedding vector + LLM SaoLa cho RAG)
FPT_AI_BASE_URL=https://api.fpt.ai/llm/v1
FPT_AI_API_KEY=your-fpt-ai-api-key-here
FPT_EMBEDDING_MODEL=bge-m3
FPT_LLM_MODEL=SaoLa4-medium

# ─── Frontend URL (dùng cho magic link trong email) ──────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Business Rules ─────────────────────────────────────────────────────────
CONTRACT_THRESHOLD=50000000
CONTRACT_DEFAULT_DAYS=365
AUTO_SEND_EMAIL=true
REFRESH_TOKEN_TTL_DAYS=7

# ─── PR Approval Ceilings ────────────────────────────────────────────────────
PR_CEILING_L1=10000000
PR_CEILING_L2=30000000
PR_CEILING_L3=100000000
