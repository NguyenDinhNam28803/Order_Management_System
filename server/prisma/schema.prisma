
datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  moduleFormat    = "commonjs"
}

model Organization {
  id                       String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                     String                   @unique @db.VarChar(20)
  name                     String                   @db.VarChar(255)
  legalName                String?                  @map("legal_name") @db.VarChar(255)
  taxCode                  String?                  @unique @map("tax_code") @db.VarChar(50)
  companyType              CompanyType              @default(BUYER) @map("company_type")
  industry                 String?                  @db.VarChar(100)
  countryCode              String                   @default("VN") @map("country_code") @db.Char(2)
  province                 String?                  @db.VarChar(100)
  address                  String?
  phone                    String?                  @db.VarChar(30)
  email                    String?                  @db.VarChar(255)
  website                  String?                  @db.VarChar(255)
  logoUrl                  String?                  @map("logo_url") @db.VarChar(500)
  isActive                 Boolean                  @default(true) @map("is_active")
  kycStatus                KycStatus                @default(PENDING) @map("kyc_status")
  kycVerifiedAt            DateTime?                @map("kyc_verified_at") @db.Timestamptz(6)
  kycVerifiedById          String?                  @map("kyc_verified_by") @db.Uuid
  supplierTier             SupplierTier             @default(PENDING) @map("supplier_tier")
  trustScore               Decimal                  @default(0) @map("trust_score") @db.Decimal(5, 2)
  metadata                 Json                     @default("{}")
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvalMatrixRules      ApprovalMatrixRule[]
  budgetAllocations        BudgetAllocation[]       @relation("BudgetAllocOrg")
  budgetPeriods            BudgetPeriod[]
  buyerRatingsAsBuyer      BuyerRating[]            @relation("BuyerRatingBuyerOrg")
  buyerRatingsAsSupplier   BuyerRating[]            @relation("BuyerRatingSupplierOrg")
  contractsAsBuyer         Contract[]               @relation("ContractBuyerOrg")
  contractsAsSupplier      Contract[]               @relation("ContractSupplierOrg")
  costCenters              CostCenter[]
  departments              Department[]
  disputesAgainst          Dispute[]                @relation("DisputeAgainstOrg")
  disputesOpened           Dispute[]                @relation("DisputeOpenedOrg")
  escrowAccounts           EscrowAccount[]
  goodsReceiptsOrg         GoodsReceipt[]
  orgBudgets               OrgBudget[]
  documents                OrganizationDocument[]
  vettingRequestsAsSupplier SupplierVettingRequest[] @relation("VettingSupplier")
  kycVerifier              User?                    @relation("OrgKycVerifier", fields: [kycVerifiedById], references: [id])
  prItems                  PrItem[]                 @relation("PreferredSupplier")
  purchaseOrdersAsBuyer    PurchaseOrder[]          @relation("PoBuyerOrg")
  purchaseOrdersAsSupplier PurchaseOrder[]          @relation("PoSupplierOrg")
  purchaseRequisitions     PurchaseRequisition[]
  rfqAwards                RfqRequest[]             @relation("RfqAwardedSupplier")
  rfqRequests              RfqRequest[]
  rfqSuppliers             RfqSupplier[]
  spendSnapshots           SpendAnalyticsSnapshot[]
  invoicesAsBuyer          SupplierInvoice[]        @relation("InvoiceBuyerOrg")
  invoicesAsSupplier       SupplierInvoice[]        @relation("InvoiceSupplierOrg")
  kpiScoresAsBuyer         SupplierKpiScore[]       @relation("KpiBuyerOrg")
  kpiScoresAsSupplier      SupplierKpiScore[]       @relation("KpiSupplier")
  supplierCategories       SupplierCategory[]
  supplierProductPrices    SupplierProductPrice[]
  systemConfigs            SystemConfig[]
  users                    User[]
  webhookConfigs           WebhookConfig[]

  @@map("organizations")
}

model OrganizationDocument {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  docType      String       @map("doc_type") @db.VarChar(50)
  docName      String       @map("doc_name") @db.VarChar(255)
  fileUrl      String       @map("file_url") @db.VarChar(500)
  issuedAt     DateTime?    @map("issued_at") @db.Date
  expiredAt    DateTime?    @map("expired_at") @db.Date
  issuingBody  String?      @map("issuing_body") @db.VarChar(255)
  isVerified   Boolean      @default(false) @map("is_verified")
  verifiedById String?      @map("verified_by") @db.Uuid
  verifiedAt   DateTime?    @map("verified_at") @db.Timestamptz(6)
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization Organization @relation(fields: [orgId], references: [id])

  @@map("organization_documents")
}

model SupplierVettingRequest {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  supplierId     String        @map("supplier_id") @db.Uuid
  requestedById  String        @map("requested_by_id") @db.Uuid
  assignedToId   String?       @map("assigned_to_id") @db.Uuid
  status         VettingStatus @default(DRAFT)
  priceVsMarket  Decimal?      @map("price_vs_market") @db.Decimal(5, 2)
  overallScore   Decimal?      @map("overall_score") @db.Decimal(5, 2)
  rejectedReason String?       @map("rejected_reason")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  supplier      Organization         @relation("VettingSupplier", fields: [supplierId], references: [id])
  requestedBy   User                 @relation("VettingRequester", fields: [requestedById], references: [id])
  assignedTo    User?                @relation("VettingAssignee", fields: [assignedToId], references: [id])
  checks        SupplierVettingCheck[]

  @@map("supplier_vetting_requests")
}

model SupplierVettingCheck {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vettingId    String   @map("vetting_id") @db.Uuid
  checkType    String   @map("check_type") @db.VarChar(50)
  checkStatus  String   @default("PENDING") @map("check_status") @db.VarChar(20)
  verifiedById String?  @map("verified_by_id") @db.Uuid
  verifiedAt   DateTime? @map("verified_at") @db.Timestamptz(6)
  fileUrl      String?  @map("file_url") @db.VarChar(500)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  vetting    SupplierVettingRequest @relation(fields: [vettingId], references: [id], onDelete: Cascade)
  verifiedBy User?                  @relation("CheckVerifier", fields: [verifiedById], references: [id])

  @@map("supplier_vetting_checks")
}

model Department {
  id                   String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId                String                @map("org_id") @db.Uuid
  code                 String                @db.VarChar(30)
  name                 String                @db.VarChar(100)
  parentDeptId         String?               @map("parent_dept_id") @db.Uuid
  budgetAnnual         Decimal               @default(0) @map("budget_annual") @db.Decimal(18, 2)
  budgetUsed           Decimal               @default(0) @map("budget_used") @db.Decimal(18, 2)
  costCenterCode       String?               @map("cost_center_code") @db.VarChar(30)
  headUserId           String?               @map("head_user_id") @db.Uuid
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  budgetAllocations    BudgetAllocation[]
  costCenters          CostCenter[]
  head                 User?                 @relation("DeptHead", fields: [headUserId], references: [id])
  organization         Organization          @relation(fields: [orgId], references: [id])
  parent               Department?           @relation("DeptHierarchy", fields: [parentDeptId], references: [id])
  children             Department[]          @relation("DeptHierarchy")
  goodsReceipts        GoodsReceipt[]        @relation("WarehouseDept")
  purchaseOrders       PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]
  users                User[]

  @@unique([orgId, code])
  @@map("departments")
}

model CostCenter {
  id                   String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId                String                @map("org_id") @db.Uuid
  deptId               String?               @map("dept_id") @db.Uuid
  code                 String                @db.VarChar(30)
  name                 String                @db.VarChar(100)
  glAccount            String?               @map("gl_account") @db.VarChar(30)
  budgetAnnual         Decimal               @default(0) @map("budget_annual") @db.Decimal(18, 2)
  budgetUsed           Decimal               @default(0) @map("budget_used") @db.Decimal(18, 2)
  currency             CurrencyCode          @default(VND)
  fiscalYear           Int?                  @map("fiscal_year") @db.SmallInt
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  budgetAllocations    BudgetAllocation[]
  department           Department?           @relation(fields: [deptId], references: [id])
  organization         Organization          @relation(fields: [orgId], references: [id])
  purchaseOrders       PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]
  poItemSources        PoItemSource[]

  @@unique([orgId, code])
  @@map("cost_centers")
}

model User {
  id                       String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId                    String                 @map("org_id") @db.Uuid
  deptId                   String?                @map("dept_id") @db.Uuid
  email                    String                 @unique @db.VarChar(255)
  phone                    String?                @db.VarChar(30)
  fullName                 String                 @map("full_name") @db.VarChar(255)
  avatarUrl                String?                @map("avatar_url") @db.VarChar(500)
  employeeCode             String?                @map("employee_code") @db.VarChar(50)
  jobTitle                 String?                @map("job_title") @db.VarChar(100)
  role                     UserRole
  isActive                 Boolean                @default(true) @map("is_active")
  isVerified               Boolean                @default(false) @map("is_verified")
  lastLoginAt              DateTime?              @map("last_login_at") @db.Timestamptz(6)
  passwordHash             String?                @map("password_hash") @db.VarChar(255)
  mfaSecret                String?                @map("mfa_secret") @db.VarChar(100)
  mfaEnabled               Boolean                @default(false) @map("mfa_enabled")
  kycStatus                KycStatus              @default(PENDING) @map("kyc_status")
  trustScore               Decimal                @default(100) @map("trust_score") @db.Decimal(5, 2)
  preferences              Json                   @default("{}")
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  hashedRefreshToken       String?                @map("hashed_refresh_token") @db.VarChar(255)
  refreshTokenExpiresAt    DateTime?              @map("refresh_token_expires_at") @db.Timestamptz(6)
  approvalMatrixRules      ApprovalMatrixRule[]
  approvalWorkflows        ApprovalWorkflow[]     @relation("ApprovalApprover")
  approvalDelegations      ApprovalWorkflow[]     @relation("ApprovalDelegatedFrom")
  approvalEscalations      ApprovalWorkflow[]     @relation("ApprovalEscalatedTo")
  budgetAllocations        BudgetAllocation[]
  buyerRatings             BuyerRating[]
  contractsCreated         Contract[]             @relation("ContractCreator")
  contractsSignedBuyer     Contract[]             @relation("ContractSignedBuyer")
  contractsSignedSupplier  Contract[]             @relation("ContractSignedSupplier")
  debitCreditApprovals     DebitCreditNote[]      @relation("DcnApprover")
  debitCreditNotes         DebitCreditNote[]      @relation("DcnIssuer")
  deptHeadOf               Department[]           @relation("DeptHead")
  disputeMessages          DisputeMessage[]
  disputesAdmin            Dispute[]              @relation("DisputeAdmin")
  disputesOpened           Dispute[]              @relation("DisputeOpener")
  escrowTransactions       EscrowTransaction[]
  grnConfirmed             GoodsReceipt[]         @relation("GrnConfirmer")
  grnInspected             GoodsReceipt[]         @relation("GrnInspector")
  grnReceived              GoodsReceipt[]         @relation("GrnReceiver")
  grnPhotos                GrnPhoto[]
  notifications            Notification[]
  orgKycVerified           Organization[]         @relation("OrgKycVerifier")
  paymentsApproved         Payment[]              @relation("PaymentApprover")
  paymentsCreated          Payment[]              @relation("PaymentCreator")
  poAmendmentApprovals     PoAmendment[]          @relation("PoAmendmentApprover")
  poAmendments             PoAmendment[]          @relation("PoAmendmentCreator")
  shipmentUpdates          PoShipmentTracking[]
  posBuyer                 PurchaseOrder[]        @relation("PoBuyer")
  posSigned                PurchaseOrder[]        @relation("PoSigned")
  requisitionsAssigned     PurchaseRequisition[]  @relation("PrProcurement")
  requisitionsCreated      PurchaseRequisition[]  @relation("PrRequester")
  rtvCreated               ReturnToVendor[]       @relation("RtvCreator")
  rtvResolved              ReturnToVendor[]       @relation("RtvResolver")
  counterOffers            RfqCounterOffer[]
  rfqQaAnswered            RfqQaThread[]          @relation("QaAnswerer")
  rfqQaAsked               RfqQaThread[]          @relation("QaAsker")
  quotationsReviewed       RfqQuotation[]         @relation("QuotationReviewer")
  rfqsCreated              RfqRequest[]
  rfqSingleSourceApprovals RfqRequest[]           @relation("RfqSingleSourceApprover")
  invoicesApproved         SupplierInvoice[]      @relation("InvoiceApprover")
  manualReviews            SupplierManualReview[]
  systemConfigUpdates      SystemConfig[]
  quotationRequests        QuotationRequest[]
  budgetOverridesReq       BudgetOverrideRequest[] @relation("BudgetOverrideRequester")
  budgetOverridesApprv     BudgetOverrideRequest[] @relation("BudgetOverrideApprover")
  delegatesReceived        UserDelegate[]         @relation("Delegate")
  delegatesGiven           UserDelegate[]         @relation("Delegator")
  vettingRequestsMade      SupplierVettingRequest[] @relation("VettingRequester")
  vettingRequestsAssigned  SupplierVettingRequest[] @relation("VettingAssignee")
  vettingChecksVerified    SupplierVettingCheck[] @relation("CheckVerifier")
  department               Department?            @relation(fields: [deptId], references: [id])
  organization             Organization           @relation(fields: [orgId], references: [id])
  webhookConfigs           WebhookConfig[]

  @@map("users")
}

model UserDelegate {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  delegatorId String   @map("delegator_id") @db.Uuid
  delegateId  String   @map("delegate_id") @db.Uuid
  role        UserRole
  scope       String?  @db.VarChar(100)
  validFrom   DateTime @map("valid_from") @db.Timestamptz(6)
  validUntil  DateTime @map("valid_until") @db.Timestamptz(6)
  reason      String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  delegate    User     @relation("Delegate", fields: [delegateId], references: [id])
  delegator   User     @relation("Delegator", fields: [delegatorId], references: [id])

  @@map("user_delegates")
}

model ApprovalMatrixRule {
  id                String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId             String       @map("org_id") @db.Uuid
  documentType      DocumentType @map("document_type")
  level             Int          @db.SmallInt
  approverRole      UserRole     @map("approver_role")
  minItemAmount     Decimal      @default(0) @map("min_item_amount") @db.Decimal(18, 2)
  minTotalAmount    Decimal      @default(0) @map("min_total_amount") @db.Decimal(18, 2)
  currency          CurrencyCode @default(VND)
  slaHours          Int          @default(8) @map("sla_hours")
  autoEscalateHours Int          @default(24) @map("auto_escalate_hours")
  isActive          Boolean      @default(true) @map("is_active")
  effectiveFrom     DateTime     @default(now()) @map("effective_from") @db.Date
  effectiveUntil    DateTime?    @map("effective_until") @db.Date
  createdById       String?      @map("created_by") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         User?        @relation(fields: [createdById], references: [id])
  organization      Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, documentType, level])
  @@map("approval_matrix_rules")
}

model ApprovalWorkflow {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  documentType    DocumentType   @map("document_type")
  documentId      String         @map("document_id") @db.Uuid
  step            Int            @db.SmallInt
  approverId      String         @map("approver_id") @db.Uuid
  delegatedFromId String?        @map("delegated_from") @db.Uuid
  status          ApprovalStatus @default(PENDING)
  comment         String?
  actionedAt      DateTime?      @map("actioned_at") @db.Timestamptz(6)
  dueAt           DateTime?      @map("due_at") @db.Timestamptz(6)
  reminderSentAt  DateTime?      @map("reminder_sent_at") @db.Timestamptz(6)
  escalatedAt     DateTime?      @map("escalated_at") @db.Timestamptz(6)
  escalatedToId   String?        @map("escalated_to") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  approver        User           @relation("ApprovalApprover", fields: [approverId], references: [id])
  delegatedFrom   User?          @relation("ApprovalDelegatedFrom", fields: [delegatedFromId], references: [id])
  escalatedTo     User?          @relation("ApprovalEscalatedTo", fields: [escalatedToId], references: [id])    
  @@index([documentType, documentId])
  @@index([approverId, status])
  @@map("approval_workflows")
}

enum ProductType {
  CATALOG
  NON_CATALOG
}

model ProductCategory {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId             String?            @map("org_id") @db.Uuid
  parentId          String?            @map("parent_id") @db.Uuid
  code              String             @db.VarChar(30)
  name              String             @db.VarChar(150)
  description       String?
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  budgetAllocations BudgetAllocation[]
  prItems           PrItem[]
  parent            ProductCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children          ProductCategory[]  @relation("CategoryHierarchy")
  supplierCategories SupplierCategory[]
  quotationRequests QuotationRequest[]
  products          Product[]
  rfqItems          RfqItem[]

  @@map("product_categories")
}

model Product {
  id           String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orgId        String?          @map("org_id") @db.Uuid
  categoryId   String?          @map("category_id") @db.Uuid
  sku          String?          @db.VarChar(100)
  name         String           @db.VarChar(255)
  description  String?
  unit         String           @default("PCS") @db.VarChar(30)
  unitPriceRef Decimal?         @map("unit_price_ref") @db.Decimal(18, 2)
  currency     CurrencyCode     @default(VND)
  type         ProductType      @default(CATALOG)
  lastPriceAt  DateTime?        @map("last_price_at") @db.Timestamptz(6)
  specSheetUrl String?          @map("spec_sheet_url") @db.VarChar(500)
  imageUrls    Json             @default("[]") @map("image_urls")
  attributes   Json             @default("{}")
  // Phân biệt loại mặt hàng dựa vào mức độ thay đổi giá
  priceVolatility    PriceVolatility           @default(STABLE)
  requiresQuoteFirst Boolean?          @default(false) @map("requires_quote_first")
  // true: Bắt buộc phải báo giá trước khi tạo PR
  lastPriceUpdate    DateTime?       @map("last_price_update") @db.Timestamptz(6)
  priceChangeFreq    Int?            @map("price_change_freq") @db.SmallInt  // Số lần thay đổi/tháng
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  prItems      PrItem[]
  supplierPrices SupplierProductPrice[]
  category     ProductCategory? @relation(fields: [categoryId], references: [id])

  @@map("products")
}

model PurchaseRequisition {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prNumber       String          @unique @map("pr_number") @db.VarChar(30)
  orgId          String          @map("org_id") @db.Uuid
  requesterId    String          @map("requester_id") @db.Uuid
  deptId         String          @map("dept_id") @db.Uuid
  costCenterId   String?         @map("cost_center_id") @db.Uuid
  status         PrStatus        @default(DRAFT)
  priority       Int             @default(2) @db.SmallInt
  title          String          @db.VarChar(255)
  description    String?
  justification  String?
  requiredDate   DateTime?       @map("required_date") @db.Date
  totalEstimate  Decimal         @default(0) @map("total_estimate") @db.Decimal(18, 2)
  currency       CurrencyCode    @default(VND)
  approvalLevel  Int             @default(1) @map("approval_level") @db.SmallInt
  fastTrack      Boolean         @default(false) @map("fast_track")
  procurementId  String?         @map("procurement_id") @db.Uuid
  submittedAt    DateTime?       @map("submitted_at") @db.Timestamptz(6)
  approvedAt     DateTime?       @map("approved_at") @db.Timestamptz(6)
  completedAt    DateTime?       @map("completed_at") @db.Timestamptz(6)
  cancelledAt    DateTime?       @map("cancelled_at") @db.Timestamptz(6)
  cancelReason   String?         @map("cancel_reason")
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  attachments    PrAttachment[]
  items          PrItem[]
  purchaseOrders PurchaseOrder[]
  poItemSources  PoItemSource[]
  costCenter     CostCenter?     @relation(fields: [costCenterId], references: [id])
  department     Department      @relation(fields: [deptId], references: [id])
  organization   Organization    @relation(fields: [orgId], references: [id])
  procurement    User?           @relation("PrProcurement", fields: [procurementId], references: [id])
  requester      User            @relation("PrRequester", fields: [requesterId], references: [id])
  rfqRequests    RfqRequest[]
  quotationRequests    QuotationRequest[]
  budgetOverrides      BudgetOverrideRequest[]

  @@index([orgId, status])
  @@index([requesterId])
  @@map("purchase_requisitions")
}

model PrItem {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prId                String              @map("pr_id") @db.Uuid
  lineNumber          Int                 @map("line_number") @db.SmallInt
  productId           String?             @map("product_id") @db.Uuid
  sku                 String?             @db.VarChar(100)
  productDesc         String              @map("product_desc") @db.VarChar(500)
  categoryId          String?             @map("category_id") @db.Uuid
  qty                 Decimal             @db.Decimal(12, 3)
  unit                String              @default("PCS") @db.VarChar(30)
  estimatedPrice      Decimal             @map("estimated_price") @db.Decimal(18, 2)
  currency            CurrencyCode        @default(VND)
  specNote            String?             @map("spec_note")
  preferredSupplierId String?             @map("preferred_supplier_id") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  poItems             PoItem[]
  poItemSources       PoItemSource[]
  category            ProductCategory?    @relation(fields: [categoryId], references: [id])
  pr                  PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)
  preferredSupplier   Organization?       @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id])
  product             Product?            @relation(fields: [productId], references: [id])
  rfqItems            RfqItem[]

  @@unique([prId, lineNumber])
  @@map("pr_items")
}

model PrAttachment {
