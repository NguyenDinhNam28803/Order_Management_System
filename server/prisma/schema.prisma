model QuotationRequest {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prId          String   @map("pr_id") @db.Uuid
  requesterId   String   @map("requester_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  description   String
  estimatedBudget Decimal? @map("estimated_budget") @db.Decimal(18, 2)
  status        QuotationRequestStatus @default(PENDING)
  // PENDING → ACKNOWLEDGED → RFQ_CREATED → PRICE_RETURNED → COMPLETED
  rfqId         String?  @map("rfq_id") @db.Uuid  // sau khi thu mua tạo RFQ
  returnedPrice Decimal? @map("returned_price") @db.Decimal(18, 2)
  note          String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  pr        PurchaseRequisition @relation(fields: [prId], references: [id])
  requester User                @relation(fields: [requesterId], references: [id])
  rfq       RfqRequest?         @relation(fields: [rfqId], references: [id])
  category  ProductCategory? @relation(fields: [categoryId], references: [id])

  @@map("quotation_requests")
}

