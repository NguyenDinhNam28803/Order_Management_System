model BudgetOverrideRequest {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  budgetAllocId    String       @map("budget_alloc_id") @db.Uuid
  prId             String       @map("pr_id") @db.Uuid
  requestedById    String       @map("requested_by") @db.Uuid
  overrideAmount   Decimal      @map("override_amount") @db.Decimal(18, 2)
  reason           String
  status           BudgetOverrideStatus @default(PENDING)
  approvedById     String?      @map("approved_by") @db.Uuid
  approvedAt       DateTime?    @map("approved_at") @db.Timestamptz(6)
  rejectedReason   String?      @map("rejected_reason")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  budgetAlloc   BudgetAllocation    @relation(fields: [budgetAllocId], references: [id])
  pr            PurchaseRequisition @relation(fields: [prId], references: [id])
  requestedBy   User   @relation("BudgetOverrideRequester", fields: [requestedById], references: [id])
  approvedBy    User?  @relation("BudgetOverrideApprover", fields: [approvedById], references: [id])

  @@map("budget_override_requests")
}

model ExternalToken {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token       String    @unique @db.VarChar(128)
  type        TokenType
  referenceId String    @map("reference_id") @db.Uuid
  targetEmail String    @map("target_email") @db.VarChar(255)
  metadata    Json      @default("{}")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([token])
  @@index([referenceId, type])
  @@map("external_tokens")
}

enum TokenType {
  RFQ_QUOTE        // NCC báo giá (thay login)
  PO_CONFIRM       // NCC confirm nhận PO
  GRN_MILESTONE    // NCC update trạng thái giao hàng
  INVOICE_SUBMIT   // NCC nộp invoice
  // APPROVAL không cần token riêng — dùng ApprovalWorkflow có sẵn
}

enum PriceVolatility {
  STABLE        // STABLE: Giá ổn định (~30 ngày không đổi) → Tạo RFQ trực tiếp
  MODERATE      // MODERATE: Giá thay đổi vừa phải (~1-2 lần/tháng) → Báo giá/RFQ
  VOLATILE      // VOLATILE: Giá thay đổi thường xuyên (>2 lần/tháng) → Yêu cầu báo giá trước
}

